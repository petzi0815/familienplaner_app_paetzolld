# ─────────────────────────────────────────────────────────────────────────────
# Familienplaner — Environment (Beispiel). Echte Werte NUR in Coolify / lokaler .env.
# Secrets niemals committen.
# ─────────────────────────────────────────────────────────────────────────────

# Laufzeit
NODE_ENV=production
PORT=3000
# Öffentliche Basis-URL (für OpenAPI-Server-URL, CORS, absolute Media-Links, iOS).
# In Coolify auf die echte Domain setzen, z.B. https://familie.paetzold.example
PUBLIC_BASE_URL=http://localhost:3000

# Persistentes Datenverzeichnis (Coolify-Volume). Enthält familienplaner.db + media/.
DATA_DIR=/data

# Git-SHA des Deployments — Coolify/GitHub liefern SOURCE_COMMIT als Build-Arg,
# das Dockerfile mappt es auf APP_GIT_SHA (für /version + Sentry-Release).
APP_GIT_SHA=dev

# ── Auth ──
# Gemeinsames Familien-Passwort für die Web-UI (Session-Login).
ADMIN_PASSWORD=change-me
# Signiert Session-Cookies (langer Zufallswert, z.B. `openssl rand -hex 32`).
SESSION_SECRET=change-me-to-a-long-random-string
# Optionaler Bootstrap-API-Key für den Agenten „Ole" beim ersten Start
# (Rolle: agent). Wird beim Boot als api_keys-Eintrag angelegt, falls gesetzt.
BOOTSTRAP_AGENT_API_KEY=

# ── Observability ──
# Sentry DSN — leer = Sentry deaktiviert.
SENTRY_DSN=
SENTRY_ENVIRONMENT=production

# ── Jobs / Scheduler ──
# In-Process-Scheduler (node-cron). 1=an (Default), 0=aus. Notify-Sends sind zusätzlich
# durch TELEGRAM_BOT_TOKEN gated (ohne Token wird nur geloggt, nichts gesendet).
JOBS_ENABLED=1

# ── APNs-Push (native iOS-App) — leer = aus. Der Auth-Key ist team-weit
# (aus dem Referenzprojekt wiederverwendbar); nur APNS_BUNDLE_ID unterscheidet sich. ──
APNS_KEY_P8=            # Inhalt der AuthKey_XXXX.p8 (PEM oder base64), einzeilig als base64 empfohlen
APNS_KEY_ID=           # 10-stellige Key-ID
# APPLE_TEAM_ID wird auch für APNs genutzt (Developer-Team-ID)
APPLE_TEAM_ID=
APNS_BUNDLE_ID=app.yagemi.familienplaner
APNS_USE_SANDBOX=0     # 1 = Dev-/Xcode-Builds (sandbox-Host als Fallback)

# ── Integrationen (optional, Jobs/KI-Funktionen — standardmäßig ungenutzt) ──
OPENAI_API_KEY=
# Telegram-Benachrichtigungen (Jobs) — leer = AUS, bis Zielkonfiguration steht.
TELEGRAM_BOT_TOKEN=
TELEGRAM_FAMILY_CHAT_ID=-1003415230540
TELEGRAM_LARS_CHAT_ID=484600941
# Smart Home
HOME_ASSISTANT_URL=
HOME_ASSISTANT_TOKEN=
# Bücher (Calibre) — optional
CALIBRE_URL=
