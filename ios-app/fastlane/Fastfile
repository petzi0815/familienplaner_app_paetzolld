require "base64"
default_platform(:ios)

APP_ID = ENV["APP_BUNDLE_ID"] || "app.yagemi.familienplaner"
WIDGET_ID = ENV["WIDGET_BUNDLE_ID"] || "#{APP_ID}.widgets"

platform :ios do
  desc "Build + Upload an internes TestFlight"
  lane :beta do
    setup_ci

    # Distribution-Zertifikat (.p12) aus base64 in den temporaeren CI-Keychain
    cert_path = "/tmp/dist_cert.p12"
    File.binwrite(cert_path, Base64.decode64(ENV.fetch("DIST_CERT_P12_BASE64")))
    import_certificate(
      certificate_path: cert_path,
      certificate_password: ENV["DIST_CERT_PASSWORD"] || "",
      keychain_name: ENV["MATCH_KEYCHAIN_NAME"] || "fastlane_tmp_keychain",
      keychain_password: ENV["MATCH_KEYCHAIN_PASSWORD"] || ""
    )

    # Provisioning-Profil App (.mobileprovision) aus base64
    app_profile = "/tmp/app.mobileprovision"
    File.binwrite(app_profile, Base64.decode64(ENV.fetch("APP_PROFILE_BASE64")))
    install_provisioning_profile(path: app_profile)

    # Provisioning-Profil Widget-Extension (App-Group-Entitlement) — die App bettet die
    # Extension ein, daher wird das Profil fuer app.yagemi.familienplaner.widgets zwingend gebraucht.
    widget_profile = "/tmp/widget.mobileprovision"
    File.binwrite(widget_profile, Base64.decode64(ENV.fetch("WIDGET_PROFILE_BASE64")))
    install_provisioning_profile(path: widget_profile)

    # App Store Connect API-Key (.p8) aus base64 — ersetzt Apple-ID-Login
    api_key = app_store_connect_api_key(
      key_id: ENV.fetch("ASC_KEY_ID"),
      issuer_id: ENV.fetch("ASC_ISSUER_ID"),
      key_content: ENV.fetch("ASC_KEY_P8_BASE64"),
      is_key_content_base64: true
    )

    # GitHub run_number ist workflow-spezifisch. Gegen TestFlight absichern,
    # damit ein anderer Workflow-Zaehler keine zu niedrige Buildnummer setzt.
    requested_build_number = (ENV["BUILD_NUMBER"] || "1").to_i
    latest_build_number = latest_testflight_build_number(
      api_key: api_key,
      app_identifier: APP_ID,
      initial_build_number: 0
    ).to_i
    build_number = [requested_build_number, latest_build_number + 1].max.to_s
    UI.message("Using TestFlight build number #{build_number}")

    build_app(
      project: "Familienplaner.xcodeproj",
      scheme: "Familienplaner",
      configuration: "Release",
      export_method: "app-store",
      xcargs: [
        "CURRENT_PROJECT_VERSION=#{build_number}",
        "DEVELOPMENT_TEAM=#{ENV['APPLE_TEAM_ID']}",
        %(CODE_SIGN_IDENTITY="Apple Distribution"),   # sonst gewinnt xcodebuilds Default "iOS Development"
        %(APP_PROFILE_NAME="#{ENV['APP_PROFILE_NAME']}"),
        %(WIDGET_PROFILE_NAME="#{ENV['WIDGET_PROFILE_NAME']}")
      ].join(" "),
      export_options: {
        signingStyle: "manual",
        provisioningProfiles: {
          APP_ID => ENV.fetch("APP_PROFILE_NAME"),
          WIDGET_ID => ENV.fetch("WIDGET_PROFILE_NAME")
        }
      }
    )

    upload_to_testflight(
      api_key: api_key,
      skip_waiting_for_build_processing: true,
      distribute_external: false
    )
  end
end
